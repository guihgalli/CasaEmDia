// Casa em Dia - Schema em português (PT/BR)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                String    @id @default(uuid())
  email             String    @unique
  senhaHash         String    @map("senha_hash")
  nome              String?
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")
  tokenRecuperacao  String?   @map("token_recuperacao")
  tokenRecuperacaoExpira DateTime? @map("token_recuperacao_expira")

  receitas         Receita[]
  despesasFixas    DespesaFixa[]
  despesasExtras   DespesaExtra[]

  @@map("usuarios")
}

model Receita {
  id           String   @id @default(uuid())
  usuarioId    String   @map("usuario_id")
  nome         String
  valor        Decimal  @db.Decimal(12, 2)
  recorrente   Boolean  @default(true)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("receitas")
}

model DespesaFixa {
  id            String   @id @default(uuid())
  usuarioId     String   @map("usuario_id")
  nome          String
  valor         Decimal  @db.Decimal(12, 2)
  diaVencimento Int      @map("dia_vencimento") // 1-31
  recorrente    Boolean  @default(true)
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("despesas_fixas")
}

model DespesaExtra {
  id          String   @id @default(uuid())
  usuarioId   String   @map("usuario_id")
  nome        String   // ex: nome do estabelecimento
  valor       Decimal  @db.Decimal(12, 2)
  data        DateTime @db.Date
  categoria   String
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("despesas_extras")
}
