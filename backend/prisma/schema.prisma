// Casa em Dia - Schema em português (PT/BR)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Casa {
  id        String   @id @default(uuid())
  nome      String?  // ex: "Casa Silva"
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuarios       Usuario[]
  receitas       Receita[]
  despesasFixas  DespesaFixa[]
  despesasExtras DespesaExtra[]

  @@map("casas")
}

model Usuario {
  id                String    @id @default(uuid())
  email             String    @unique
  senhaHash         String    @map("senha_hash")
  nome              String?
  casaId            String?   @map("casa_id")
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")
  tokenRecuperacao  String?   @map("token_recuperacao")
  tokenRecuperacaoExpira DateTime? @map("token_recuperacao_expira")

  casa Casa? @relation(fields: [casaId], references: [id], onDelete: SetNull)

  @@map("usuarios")
}

model Receita {
  id           String   @id @default(uuid())
  casaId       String   @map("casa_id")
  nome         String
  valor        Decimal  @db.Decimal(12, 2)
  recorrente   Boolean  @default(true)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  casa Casa @relation(fields: [casaId], references: [id], onDelete: Cascade)

  @@map("receitas")
}

model DespesaFixa {
  id            String   @id @default(uuid())
  casaId        String   @map("casa_id")
  nome          String
  valor         Decimal  @db.Decimal(12, 2)
  diaVencimento Int      @map("dia_vencimento") // 1-31
  recorrente    Boolean  @default(true)
  quantidadeParcelas Int? @map("quantidade_parcelas")
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  casa Casa @relation(fields: [casaId], references: [id], onDelete: Cascade)

  @@map("despesas_fixas")
}

model DespesaExtra {
  id          String   @id @default(uuid())
  casaId      String   @map("casa_id")
  nome        String   // ex: nome do estabelecimento
  valor       Decimal  @db.Decimal(12, 2)
  data        DateTime @db.Date
  categoria   String
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  casa Casa @relation(fields: [casaId], references: [id], onDelete: Cascade)

  @@map("despesas_extras")
}

model Objetivo {
  id           String            @id @default(uuid())
  casaId       String            @map("casa_id")
  nome         String
  valorMeta    Decimal           @db.Decimal(12, 2) @map("valor_meta")
  concluido    Boolean           @default(false)
  criadoEm     DateTime          @default(now()) @map("criado_em")
  atualizadoEm DateTime          @updatedAt @map("atualizado_em")

  casa     Casa             @relation(fields: [casaId], references: [id], onDelete: Cascade)
  aportes  AporteObjetivo[]

  @@map("objetivos")
}

model AporteObjetivo {
  id          String   @id @default(uuid())
  objetivoId  String   @map("objetivo_id")
  valor       Decimal  @db.Decimal(12, 2)
  data        DateTime @db.Date
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  objetivo Objetivo @relation(fields: [objetivoId], references: [id], onDelete: Cascade)

  @@map("aportes_objetivos")
}
