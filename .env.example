# ===========================================
# Casa em Dia - Variáveis de ambiente
# Copie para .env e preencha. NUNCA commite .env
# ===========================================

# --- Obrigatório em produção ---
NODE_ENV=production

# Banco PostgreSQL
POSTGRES_PASSWORD=defina_uma_senha_forte_min_16_chars

# Backend - JWT (obrigatório em produção, mínimo 16 caracteres cada)
JWT_SECRET=seu_jwt_secret_longo_e_seguro_min_16
JWT_REFRESH_SECRET=seu_refresh_secret_longo_e_seguro_min_16

# URL do frontend (obrigatório em produção para CORS)
# Com portas 8080/8443: https://seu-dominio.com.br:8443 ou http://seu-dominio.com.br:8080 (sem barra no final)
FRONTEND_URL=https://seu-dominio.com.br:8443

# --- Opcional ---
# Porta da API (padrão 3000)
# PORT=3000

# Frontend: deixe vazio quando usar mesmo domínio (Nginx proxy)
# Só defina se o frontend chamar a API por outro host
# VITE_API_URL=
